# Gemini / Vertex AI
MODEL_ANALYSIS=gemini-2.5-flash
MODEL_TTS=gemini-2.5-pro-preview-tts
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account.json

# TTS provider (default: Gemini)
TTS_PROVIDER=gemini
GEMINI_TTS_VOICE=Puck

# Optional: ElevenLabs (only if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb


# Optional: Use mock TTS for testing (no API key needed)
USE_MOCK_TTS=false

# Backend URL (for frontend)
VITE_API_URL=http://localhost:8000
